# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Neon Postgres connection string. Use a separate Neon branch for local dev
# vs. production so migrations/data never mix — see README/CLAUDE.md notes.
DATABASE_URL="postgresql://user:password@ep-example-000000.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Used as the base URL for page metadata (Open Graph/Twitter tags, canonical
# links). Defaults to http://localhost:3000 if unset. Set to the real domain
# in production.
SITE_URL="http://localhost:3000"

# Secret used by Better Auth to sign sessions/tokens. Generate a real value
# with `openssl rand -base64 32` (or `npx @better-auth/cli secret`) — never
# reuse this placeholder.
BETTER_AUTH_SECRET="replace-with-openssl-rand--base64-32"
# Base URL Better Auth uses for its API routes/cookies. Set to the real domain
# in production.
BETTER_AUTH_URL="http://localhost:3000"
