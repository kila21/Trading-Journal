// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Trade/Account (trading) modeling is still a future phase — these models are
// Better Auth's own schema (User/Session/Account/Verification), generated via
// `npx @better-auth/cli generate --config src/lib/auth.ts`.

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  trades        Trade[]
  setups        Setup[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// direction is a plain string ("long" | "short"), validated in
// src/lib/validate-trade.ts — kept as a string rather than a Postgres enum to
// avoid an enum migration for what's still a 2-value field.
model Trade {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol     String
  direction  String
  entryPrice Float
  exitPrice  Float
  takeProfit Float?
  stopLoss   Float?
  // Number of contracts/units held — not a dollar position size. Combined
  // with entry/stop price distance to derive dollar risk for R-multiples
  // (see computeAchievedR in trade-stats.ts).
  contracts  Float
  pnl        Float
  tradeDate  DateTime
  // Nullable — only set when the trader records an exit time. Shares the
  // same calendar day as tradeDate (see trade-form.tsx); used for hold
  // duration, not as an independent multi-day timestamp.
  exitDate   DateTime?
  notes      String?
  // Fixed vocabularies (src/config/trade-setups.ts, trade-mistake-tags.ts),
  // kept as plain strings/array rather than enums for the same reason as
  // `direction` above — no migration needed when the list changes.
  setup        String?
  mistakeTags  String[] @default([])
  followedPlan Boolean?
  // Snapshot of the exact Setup.conditions text strings checked at save
  // time — not a live link to condition IDs, so it survives the setup's
  // conditions being edited/reordered/deleted later without corrupting
  // trade history ("saved as taken", not re-derived).
  checkedConditions String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  images     TradeImage[]

  @@index([userId, tradeDate])
  @@map("trade")
}

// The trader's playbook. status/sessions/instruments are plain
// strings/arrays (validated in src/lib/validate-setup.ts), same non-enum
// rationale as Trade.direction/setup above. Trade.setup soft-references
// this by name (no FK) — deliberately, so a trade's history survives a
// setup being renamed or retired.
model Setup {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      String   @default("active")
  conditions  String[] @default([])
  stopRule    String?
  targetRule  String?
  minR        Float?
  sessions    String[] @default([])
  instruments String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@map("setup")
}

model TradeImage {
  id         String   @id @default(cuid())
  tradeId    String
  trade      Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  timeframe  String
  storageKey String
  mimeType   String
  caption    String?
  createdAt  DateTime @default(now())

  @@index([tradeId])
  @@map("trade_image")
}
